import asyncio
import json
import logging
import ipywidgets as widgets
from IPython.display import display
from web3 import Web3
from web3.middleware import ExtraDataToPOAMiddleware
from datetime import datetime

# ==========================================
# 1. VISUAL DASHBOARD SETUP (ipywidgets)
# ==========================================
header = widgets.HTML(value="<h2>🌐 Live Testnet Agent: Base Sepolia</h2>")

# Metrics Display
ui_status = widgets.HTML(value="<b>Status:</b> 🟡 Connecting...")
ui_block = widgets.HTML(value="<b>Current Block:</b> Syncing...")
ui_earnings = widgets.HTML(value="<b>Total Earnings:</b> 0.0 USDC")

metrics_box = widgets.HBox([ui_status, ui_block, ui_earnings], 
                           layout=widgets.Layout(justify_content='space-between', border='1px solid #4CAF50', padding='10px', margin='0 0 10px 0'))

# Log Terminal
ui_terminal = widgets.HTML(
    value="<div style='background-color: #1e1e1e; color: #00ff00; padding: 10px; font-family: monospace; height: 250px; overflow-y: scroll;'>Waiting for initialization...</div>",
    layout=widgets.Layout(margin='10px 0 0 0')
)

dashboard = widgets.VBox([header, metrics_box, ui_terminal])
display(dashboard)

# Global state for UI updates
app_state = {
    "logs": [],
    "total_usdc": 0.0
}

def write_log(msg, color="#00ff00"):
    """Pushes a new log to the visual terminal."""
    timestamp = datetime.now().strftime("%H:%M:%S")
    formatted_msg = f"[{timestamp}] <span style='color:{color}'>{msg}</span>"
    app_state["logs"].append(formatted_msg)
    
    # Keep the last 15 lines so the DOM doesn't get too heavy
    log_html = "<br>".join(app_state["logs"][-15:])
    ui_terminal.value = f"<div style='background-color: #1e1e1e; color: #00ff00; padding: 10px; font-family: monospace; height: 250px; overflow-y: scroll;'>{log_html}</div>"

# ==========================================
# 2. WEB3 AGENT LOGIC
# ==========================================
class CROOTestnetVisualClient:
    def __init__(self, private_key: str, rpc_url: str, contract_address: str):
        write_log("Connecting to Base Sepolia RPC...")
        self.w3 = Web3(Web3.HTTPProvider(rpc_url))
        self.w3.middleware_onion.inject(ExtraDataToPOAMiddleware, layer=0)
        
        if not self.w3.is_connected():
            write_log("FAILED to connect to RPC.", color="#ff0000")
            ui_status.value = "<b>Status:</b> 🔴 Disconnected"
            return
            
        self.account = self.w3.eth.account.from_key(private_key)
        self.agent_address = self.account.address
        self.contract_address = self.w3.to_checksum_address(contract_address)
        
        write_log(f"Connected. Agent Wallet: {self.agent_address}")
        ui_status.value = "<b>Status:</b> 🟢 Listening"
        
        self.abi = json.loads('''[
            {
                "anonymous": false,
                "inputs": [
                    {"indexed": true, "internalType": "bytes32", "name": "orderId", "type": "bytes32"},
                    {"indexed": true, "internalType": "address", "name": "agent", "type": "address"},
                    {"indexed": false, "internalType": "uint256", "name": "amountUSDC", "type": "uint256"}
                ],
                "name": "OrderPaid",
                "type": "event"
            }
        ]''')
        self.contract = self.w3.eth.contract(address=self.contract_address, abi=self.abi)

    async def listen_for_payments(self):
        last_checked_block = self.w3.eth.block_number
        write_log(f"Starting block scan from: {last_checked_block}")
        
        while True:
            try:
                current_block = self.w3.eth.block_number
                
                # Update UI Metric
                ui_block.value = f"<b>Current Block:</b> {current_block}"
                
                if current_block > last_checked_block:
                    write_log(f"Scanning blocks {last_checked_block + 1} to {current_block}...", color="#aaaaaa")
                    
                    # FIXED: Using stateless get_logs() to bypass public RPC memory limits
                    new_events = self.contract.events.OrderPaid.get_logs(
                        from_block=last_checked_block + 1,
                        to_block=current_block,
                        argument_filters={"agent": self.agent_address} 
                    )
                    
                    for event in new_events:
                        self._process_payment(event)
                        
                    last_checked_block = current_block
                
                await asyncio.sleep(2)
                
            except Exception as e:
                write_log(f"RPC Error: {e}", color="#ff0000")
                await asyncio.sleep(5)
        
        while True:
            try:
                current_block = self.w3.eth.block_number
                
                # Update UI Metric
                ui_block.value = f"<b>Current Block:</b> {current_block}"
                
                if current_block > last_checked_block:
                    write_log(f"Scanning blocks {last_checked_block + 1} to {current_block}...", color="#aaaaaa")
                    
                    event_filter = self.contract.events.OrderPaid.create_filter(
                        from_block=last_checked_block + 1,
                        to_block=current_block,
                        argument_filters={"agent": self.agent_address} 
                    )
                    
                    for event in event_filter.get_all_entries():
                        self._process_payment(event)
                        
                    last_checked_block = current_block
                
                await asyncio.sleep(2)
                
            except Exception as e:
                write_log(f"RPC Error: {e}", color="#ff0000")
                await asyncio.sleep(5) 

    def _process_payment(self, event):
        tx_hash = event['transactionHash'].hex()
        amount_usdc = event['args']['amountUSDC'] / 10**6 
        
        # Update State & UI
        app_state["total_usdc"] += amount_usdc
        ui_earnings.value = f"<b>Total Earnings:</b> <span style='color: #00ff00'>{app_state['total_usdc']:.2f} USDC</span>"
        
        write_log(" ON-CHAIN PAYMENT VERIFIED! ", color="#ffdd00")
        write_log(f"Earned: {amount_usdc} USDC | Tx: {tx_hash[:10]}...", color="#ffdd00")

# ==========================================
# 3. BACKGROUND EXECUTION LAUNCHER
# ==========================================
BASE_SEPOLIA_RPC = "https://sepolia.base.org"
CROO_ESCROW_CONTRACT = "0x0000000000000000000000000000000000000000" 
AGENT_PRIVATE_KEY = "YOUR_PRIVATE_KEY" 

# Initialize class
agent_node = CROOTestnetVisualClient(AGENT_PRIVATE_KEY, BASE_SEPOLIA_RPC, CROO_ESCROW_CONTRACT)

# Launch into the background! This prevents the [*] hanging issue.
bg_task = asyncio.create_task(agent_node.listen_for_payments())

write_log("Background task launched successfully. The cell is now free.", color="#00ffff")


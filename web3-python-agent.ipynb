def log_msg(msg):
    """Adds a message to the simulated terminal."""
    timestamp = datetime.now().strftime("%H:%M:%S")
    state["logs"].append(f"[{timestamp}] {msg}")
    # Keep only last 10 logs to avoid massive HTML payloads
    recent_logs = state["logs"][-15:]
    log_html = "<br>".join(recent_logs)
    terminal.value = f"<div style='background-color: #1e1e1e; color: #00ff00; padding: 10px; font-family: monospace; height: 200px; overflow-y: scroll;'>{log_html}</div>"

def update_ui():
    """Refreshes the display values based on current state."""
    val_status.value = f"<b>Status:</b> {state['status']}"
    val_balance.value = f"<b>Wallet Balance:</b> {state['balance']:.2f} USDC"
    val_jobs.value = f"<b>Jobs Completed:</b> {state['jobs']}"
    
    if state["active_job"]:
        job = state["active_job"]
        job_details.value = f"<b>Requester:</b> {job['did']} <br> <b>Task:</b> {job['task']} <br> <b>Price:</b> {job['price']} USDC"
    else:
        job_details.value = "<i>No active jobs. Waiting for network events...</i>"

def trigger_job(task_name, price):
    if state["status"] not in [" Idle", " Completed", " Rejected"]:
        log_msg("Agent is busy! Cannot accept new job right now.")
        return
        
    log_msg(f"Incoming Network Event: {task_name} at {price} USDC")
    state["active_job"] = {"did": "did:croo:agent:random_client", "task": task_name, "price": price}
    
    # Pricing threshold logic
    if price < 6.0:
        state["status"] = "Rejected"
        log_msg(f" REJECTED: Price {price} USDC is below minimum threshold of 6.0 USDC.")
        state["active_job"] = None
    else:
        state["status"] = " Negotiating"
        log_msg(" Price acceptable. Entering negotiation phase.")
        
    update_ui()

def step_phase(b):
    current = state["status"]
    
    if current == " Idle" or current == " Rejected":
        log_msg(" Nothing to process. Trigger a job first.")
        return
        
    if current == " Completed":
        state["status"] = " Idle"
        state["active_job"] = None
        log_msg(" Resetting to Idle state.")
        update_ui()
        return

    # Pipeline logic
    if current == " Negotiating":
        state["status"] = " Payment Pending"
        log_msg(" Negotiation accepted. Awaiting on-chain OrderPaid event...")
    elif current == " Payment Pending":
        state["status"] = " Computing"
        log_msg(f" Payment verified on-chain. Processing task: {state['active_job']['task']}...")
    elif current == " Computing":
        state["status"] = " Delivering"
        log_msg(" Compute finished. Packaging payload and delivering to network...")
    elif current == " Delivering":
        state["status"] = " Completed"
        price = state["active_job"]["price"]
        state["balance"] += price
        state["jobs"] += 1
        log_msg(f" OrderCompleted. Earned {price} USDC!")
        
    update_ui()

# Bind buttons to functions
btn_audit.on_click(lambda b: trigger_job("Smart Contract Audit", 10.5))
btn_defi.on_click(lambda b: trigger_job("DeFi Monitoring", 5.0))
btn_data.on_click(lambda b: trigger_job("Data Verification", 15.0))
btn_step.on_click(step_phase)

